# 전부 서버 전용. NEXT_PUBLIC_ 접두사를 절대 붙이지 말 것.
# (브라우저는 Convex 를 직접 부르지 않는다 — 배포 URL 도 알 필요가 없다)

# npx convex dev 가 .env.local 에 자동으로 써 준다
CONVEX_DEPLOYMENT=
CONVEX_URL=https://abundant-retriever-951.convex.cloud

# Next.js ↔ Convex 함수 호출 시크릿. Convex 대시보드 환경변수에도 같은 값을 넣는다.
SERVER_SECRET=

# 관리자 화면 로그인 비번
ADMIN_PASSWORD=

# 쿠키 서명용. 32자 이상 무작위 문자열
SESSION_SECRET=

# 개발자 마스터 비번(선택) — 설정하면 어느 글이든 이 비번으로 열람·수정·삭제 가능
MASTER_PASSWORD=
